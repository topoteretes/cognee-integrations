# Local cognee (default): the nodes run cognee IN-PROCESS and build the graph with
# an LLM, so you just need an LLM config. No COGNEE_* server vars are used locally.
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional — local embeddings with no separate embedding key (avoids OpenAI embeddings):
# EMBEDDING_PROVIDER=fastembed
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSIONS=384

# Advanced (optional) — use a REMOTE cognee (e.g. Cognee Cloud) instead of the local
# in-process pipeline. cognee only talks to a remote instance when your code calls
# cognee.serve(url=..., api_key=...) before remember/recall. This example runs cognee
# locally and does not call serve(); wiring remote mode is a future enhancement.
