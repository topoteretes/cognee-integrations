# A running cognee server (holds the LLM_API_KEY and builds/queries memory).
COGNEE_BASE_URL=http://localhost:8000
# Omit for a local cognee with access control disabled.
COGNEE_API_KEY=

# Where the widget backend itself listens.
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Demo "ask our docs" site id, and CORS allow-list (comma-separated; "*" = any).
WIDGET_SITE_ID=demo
WIDGET_ALLOWED_ORIGINS=*
