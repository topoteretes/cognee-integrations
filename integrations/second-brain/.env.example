# Copy to .env and fill in. The .env is gitignored; never commit real secrets.

# --- cognee server (holds the LLM_API_KEY and builds/queries memory) ---
# The bot talks to this over HTTP; it needs no in-process cognee and no LLM key.
COGNEE_BASE_URL=http://localhost:8000
# Omit for a local cognee with access control disabled.
COGNEE_API_KEY=

# --- Telegram transport (optional) ---
# Token from @BotFather. When set, the Telegram transport runs alongside the web one.
TELEGRAM_BOT_TOKEN=

# --- Web transport ---
# Loopback by default: the bot runs without auth, so binding to all interfaces
# would expose a private brain to the network. Set WEB_HOST=0.0.0.0 to expose it
# (e.g. inside a container).
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Set REQUIRE_OPTIN=true to require /optin before any note is captured.
REQUIRE_OPTIN=false
# Set USE_FAKE_ADAPTER=true to run the in-memory adapter with no cognee server
# (great for a first look; substring recall instead of semantic).
USE_FAKE_ADAPTER=false
