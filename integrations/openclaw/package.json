{
  "name": "@cognee/cognee-openclaw",
  "version": "2026.4.12",
  "type": "module",
  "description": "OpenClaw Cognee-backed memory plugin with auto-recall/capture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.\\.?/.*)\\.js$": "$1"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.2.0",
    "openclaw": "2026.4.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "tar": "7.5.7"
  }
}
