{
  "id": "cognee-openclaw",
  "name": "Memory (Cognee)",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "description": "Cognee API base URL (default: http://localhost:8000)"
      },
      "apiKey": {
        "type": "string",
        "description": "Cognee API key (or use ${COGNEE_API_KEY})"
      },
      "username": {
        "type": "string",
        "description": "Cognee login username (default: default_user@example.com)"
      },
      "password": {
        "type": "string",
        "description": "Cognee login password (default: default_password)"
      },
      "datasetName": {
        "type": "string",
        "description": "Cognee dataset name to store memories in"
      },
      "datasetNames": {
        "type": "object",
        "description": "Per-agent dataset names keyed by agent id (falls back to datasetName)",
        "additionalProperties": {
          "type": "string"
        }
      },
      "searchType": {
        "type": "string",
        "enum": [
          "GRAPH_COMPLETION",
          "CHUNKS",
          "SUMMARIES"
        ],
        "description": "Cognee search mode"
      },
      "deleteMode": {
        "type": "string",
        "enum": [
          "soft",
          "hard"
        ],
        "description": "Cognee delete mode: 'soft' removes raw data only, 'hard' also removes degree-one graph nodes (default: soft)"
      },
      "maxResults": {
        "type": "number",
        "description": "Max recall results to inject (default: 6)"
      },
      "minScore": {
        "type": "number",
        "description": "Minimum score to include in recall (default: 0)"
      },
      "maxTokens": {
        "type": "number",
        "description": "Token cap for recall (default: 512)"
      },
      "autoRecall": {
        "type": "boolean",
        "description": "Inject memories before each agent run (default: true)"
      },
      "autoIndex": {
        "type": "boolean",
        "description": "Auto-sync memory files to Cognee on plugin startup (default: true)"
      },
      "autoCognify": {
        "type": "boolean",
        "description": "Run cognify after new memories are added (default: true)"
      },
      "requestTimeoutMs": {
        "type": "number",
        "description": "HTTP timeout in milliseconds for Cognee requests (default: 60000)"
      },
      "ingestionTimeoutMs": {
        "type": "number",
        "description": "HTTP timeout in milliseconds for add/update (ingestion) requests, which are typically slower (default: 300000 = 5 min)"
      },
      "searchPrompt": {
        "type": "string",
        "description": "System prompt sent to Cognee to guide search query processing (default: '')"
      }
    }
  },
  "uiHints": {
    "baseUrl": {
      "label": "Base URL",
      "placeholder": "http://localhost:8000"
    },
    "apiKey": {
      "label": "API Key",
      "sensitive": true,
      "placeholder": "${COGNEE_API_KEY}"
    },
    "username": {
      "label": "Username",
      "placeholder": "default_user@example.com"
    },
    "password": {
      "label": "Password",
      "sensitive": true,
      "placeholder": "default_password"
    },
    "datasetName": {
      "label": "Dataset Name",
      "placeholder": "openclaw"
    },
    "datasetNames": {
      "label": "Dataset Names (per-agent)",
      "placeholder": "{\"asst\":\"asst\",\"lawyer\":\"lawyer\"}"
    },
    "searchType": {
      "label": "Search Type",
      "placeholder": "GRAPH_COMPLETION"
    },
    "deleteMode": {
      "label": "Delete Mode",
      "placeholder": "soft"
    },
    "maxResults": {
      "label": "Max Results",
      "placeholder": "6"
    },
    "minScore": {
      "label": "Min Score",
      "placeholder": "0"
    },
    "maxTokens": {
      "label": "Max Tokens",
      "placeholder": "512"
    },
    "autoRecall": {
      "label": "Auto-Recall"
    },
    "autoIndex": {
      "label": "Auto-Index on Startup"
    },
    "autoCognify": {
      "label": "Auto-Cognify"
    },
    "requestTimeoutMs": {
      "label": "Request Timeout (ms)",
      "placeholder": "60000"
    },
    "ingestionTimeoutMs": {
      "label": "Ingestion Timeout (ms)",
      "placeholder": "300000"
    }
  }
}