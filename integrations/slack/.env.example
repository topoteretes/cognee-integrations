# Slack app credentials (Socket Mode).
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Optional Slack settings.
COGNEE_SLACK_DEFAULT_TEAM_ID=
COGNEE_SLACK_OPTED_IN_CHANNELS=
COGNEE_SLACK_COGNIFY_BATCH=10

# A running cognee server (holds the LLM_API_KEY and builds/queries memory).
COGNEE_BASE_URL=http://localhost:8000
# Omit for a local cognee with access control disabled.
COGNEE_API_KEY=
