# ==============================================================================
# COGNEE INTEGRATION FOR AIDER CLI - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and adjust the variables based on your environment.
# Precedence Hierarchy: SYSTEM ENVIRONMENT VARIABLES > .env > DEFAULTS
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE COGNEE ORCHESTRATION MODE
# ------------------------------------------------------------------------------
# Choose how Cognee runs its storage, extraction, and graph indexing.
# Options: 
#   - 'local' (Runs embedded vector/graph engines directly inside your workspace)
#   - 'cloud' (Routes graph execution pipelines to a remote hosted service layer)
COGNEE_MEMORY_MODE=local

# The target API endpoint and verification key for the Cognee engine.
# Leave as localhost if running a self-hosted docker/service layout locally.
COGNEE_SERVICE_URL=http://localhost:8000
COGNEE_API_KEY=mock-api-key-1234


# ------------------------------------------------------------------------------
# VARIATION A: OPENAI / ANTHROPIC CLOUD ENDPOINTS (Default standard approach)
# ------------------------------------------------------------------------------
# Use this block if you want high-fidelity reasoning using mainstream cloud LLMs.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your_real_openai_api_key_here
# LLM_API_KEY=your_real_openai_api_key_here


# ------------------------------------------------------------------------------
# VARIATION B: COGNEE HOUSED CLOUD INFRASTRUCTURE
# ------------------------------------------------------------------------------
# Use this block if you are connecting directly to Cognee's managed platform.
# COGNEE_MEMORY_MODE=cloud
# COGNEE_SERVICE_URL=https://cognee.ai
# COGNEE_API_KEY=your_official_cognee_dashboard_token


# ------------------------------------------------------------------------------
# VARIATION C: 100% LOCAL OFFLINE INFRASTRUCTURE (Ollama)
# ------------------------------------------------------------------------------
# Use this block to bypass all usage costs and run entirely inside WSL/Linux.
# Ensure the Ollama background daemon is running (`ollama serve`).
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_INSTRUCTOR_MODE=json_mode          # <-- Add this

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=all-minilm
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=384
HUGGINGFACE_TOKENIZER=sentence-transformers/all-MiniLM-L6-v2

# ------------------------------------------------------------------------------
# 2. INTERNAL BACKEND CONSTRAINTS
# ------------------------------------------------------------------------------
# Disable multi-user tenant authorization validation checks during local debugging.
ENABLE_BACKEND_ACCESS_CONTROL=false

# Force Cognee to skip the connection timeout verification step
COGNEE_SKIP_CONNECTION_TEST=true