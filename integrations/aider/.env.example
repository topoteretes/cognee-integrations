# Cognee memory for Aider — environment configuration.
# Copy to `.env` and adjust for your provider. cognee reads these at runtime;
# precedence is: real environment variables > .env > cognee defaults.
#
# The default below runs entirely locally and for free via Ollama
# (`ollama serve`). Comment it out and use the OpenAI block instead for a
# hosted model.

# --- Local, free: Ollama ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=all-minilm
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=384

# Local single-user runs don't need multi-tenant access control.
ENABLE_BACKEND_ACCESS_CONTROL=false

# --- Hosted alternative: OpenAI (uncomment and set your key) ---
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# LLM_API_KEY=sk-...
